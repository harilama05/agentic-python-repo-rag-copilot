# ─── LLM ─────────────────────────────────────────────────────────
# Set your OpenAI API key to enable LLM-powered answer generation.
# Without this, the system will still work but will return raw
# retrieved context instead of natural-language answers.
OPENAI_API_KEY=

# ─── Models ──────────────────────────────────────────────────────
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# CROSS_ENCODER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
# LLM_MODEL=gpt-4o-mini
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=2048
