GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
LLM_BACKEND=gemini

# App containers use the compose Postgres service by default.
DOCKER_DATABASE_URL=postgresql+psycopg://rag_user:rag_password@postgres:5432/rag_db

EMBEDDING_DIMENSION=384
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8501
